{
  "name": "pi-lot-ui",
  "version": "0.1.0",
  "description": "Web UI for interacting with the pi coding agent remotely through a tunnel",
  "type": "module",
  "main": "server.mjs",
  "scripts": {
    "start": "node server.mjs",
    "dev": "vite --config vite.config.js",
    "build": "vite build --config vite.config.js",
    "preview": "vite preview --config vite.config.js",
    "test": "node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "svelte": "^5.35.0",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "license": "MIT"
}
